<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Interactive circle explorer</title>
<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: #fafaf8;
    color: #1a1a1a;
    padding: 40px 20px;
    display: flex;
    justify-content: center;
  }
  .wrap {
    display: flex;
    gap: 32px;
    align-items: center;
    flex-wrap: wrap;
    max-width: 560px;
  }
  svg { flex-shrink: 0; }
  .controls { flex: 1; min-width: 220px; }
  .slider-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1.5rem;
  }
  .slider-row label {
    font-size: 14px;
    color: #666;
    min-width: 50px;
  }
  .slider-row span {
    font-size: 14px;
    font-weight: 600;
    min-width: 40px;
    text-align: right;
  }
  input[type="range"] { flex: 1; }
  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .card {
    background: #f0efe9;
    border-radius: 8px;
    padding: 1rem;
  }
  .card.wide { grid-column: span 2; }
  .card p:first-child {
    font-size: 13px;
    color: #666;
    margin: 0 0 4px;
  }
  .card p:last-child {
    font-size: 20px;
    font-weight: 600;
    margin: 0;
  }
</style>
</head>
<body>

<div class="wrap">
  <svg width="220" height="220" viewBox="0 0 220 220">
    <circle id="circ" cx="110" cy="110" r="80" fill="none" stroke="#7f77dd" stroke-width="2"/>
    <line id="rline" x1="110" y1="110" x2="190" y2="110" stroke="#333" stroke-width="1.5"/>
    <circle cx="110" cy="110" r="3" fill="#333"/>
  </svg>

  <div class="controls">
    <div class="slider-row">
      <label for="radius">Radius</label>
      <input type="range" min="10" max="100" step="1" value="80" id="radius">
      <span id="r-out">80</span>
    </div>
    <div class="stats">
      <div class="card">
        <p>Diameter</p>
        <p id="d-out">160</p>
      </div>
      <div class="card">
        <p>Circumference</p>
        <p id="c-out">502.65</p>
      </div>
      <div class="card wide">
        <p>Area</p>
        <p id="a-out">20106.19</p>
      </div>
    </div>
  </div>
</div>

<script>
  const slider = document.getElementById('radius');
  const circ = document.getElementById('circ');
  const rline = document.getElementById('rline');

  function update(r) {
    const scale = 80 / 100;
    const drawR = r * scale;
    circ.setAttribute('r', drawR);
    rline.setAttribute('x2', 110 + drawR);

    document.getElementById('r-out').textContent = r;
    document.getElementById('d-out').textContent = (r * 2).toFixed(0);
    document.getElementById('c-out').textContent = (2 * Math.PI * r).toFixed(2);
    document.getElementById('a-out').textContent = (Math.PI * r * r).toFixed(2);
  }

  slider.addEventListener('input', e => update(Number(e.target.value)));
  update(80);
</script>

</body>
</html>
